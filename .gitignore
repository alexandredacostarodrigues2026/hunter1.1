# Runtime Python (binário, regenerável via launcher/setup_ambiente.bat)
**/runtime/
**/runtime_OLD_venv_backup/

# Cache/bytecode Python
__pycache__/
*.pyc

# Logs e temporários
**/logs/
**/temp/
**/_pyinstaller_work/
**/_pyinstaller_spec/
**/_SNAPSHOTS/

# Bancos de dados locais (binários, regeneráveis)
**/banco/*.db
**/banco/*.duckdb

# Dados fiscais brutos e sensíveis (CNPJ, valores financeiros) — não
# versionados por padrão (volume grande + dado sensível de cliente).
# Revisar com o usuário se isso deve mudar.
**/1-DOCFISCAIS/
**/2-DECLARACAO/
**/qlik/*.csv
**/exports/
DADOS/
/DADOS BRUTOS/

# Arquivos avulsos vazios na raiz (resíduo de algum comando, sem extensão/uso identificado)
/Python
/venv

# config.json de operações reais contém CNPJ/Razão Social do cliente
# auditado — excluído por padrão. O config.json do MODELO (sem dado real)
# fica versionado normalmente.
OPERACOES/*/ESSENCIAL/config/config.json
OPERACOES/*/config.json
!OPERACOES/_MODELO_OPERACAO/config.json

# Repositórios git aninhados (histórico próprio, fora deste repo)
/ANTIGO_geraldo_2020_2024_5/
/DADOS_HUNTER_1a/

# Build do executável (gerado via build_exe.bat)
**/*.spec
*.exe

# Heranca do .gitignore-semente do repositorio remoto
EFD/
NF/
*.zip
.claude/settings.local.json

# Arquivos temporarios do Office (lock files)
~$*.xlsx
~$*.docx

# Documentos pesados de exemplo em "regra de negócios unificadas/" (podem
# conter notas fiscais reais de exemplo) — versiona-se só o texto puro
# (.txt) das regras, não os anexos binários (PDF/docx/xlsx).
regra de negócios unificadas/**/*.pdf
regra de negócios unificadas/**/*.docx
regra de negócios unificadas/**/*.xlsx

# Excel de referência de outra aplicação do usuário, colado direto na pasta
# da operação (ex.: "TABELA ENTRADAS A SE EXPORTADA AO HUNTER(<uuid>).xlsx",
# "ESTOQUE(<uuid>).xlsx", "COMETA EMPRESA.xlsx" — nome varia por
# operação/distribuidora, ver loader._localizar_excel_entradas_referencia())
# — dado fiscal real do cliente (descrição de produto, valores, CNPJ),
# usado só como insumo local pra estudos de divergência
# (loader.auditar_divergencia_entradas()), não deve ser versionado.
# Padrão genérico (qualquer .xlsx solto na raiz da operação) em vez de
# tentar prever cada convenção de nome por distribuidora — achado real
# 2026-07-16: "COMETA EMPRESA.xlsx" não batia com nenhum dos 2 padrões
# antigos (TABELA .../ESTOQUE(...) e quase foi commitado por engano.
OPERACOES/*/*.xlsx

# Exports de teste sob demanda (ver loader — bc3_matching.csv/
# sped_entradas_terceiros.csv por operação) — contêm descrição de
# produto/valores reais do cliente, mesma política acima.
/testes_match_b3/
